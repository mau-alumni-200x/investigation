---
// Content section - Main text area with event details

import { asset } from '../utils/paths.js'
---

<section class="content">
  <img src={asset('assets/imgs/tagline.svg')} alt="">
  <h2>武蔵野美術大学<br />2006年卒業生同窓会のご案内</h2>
  <!-- Main Text -->
  <p>
    2026年11月。<br>
    卒業後20周年を迎える節目の年に、<br>
    同期生が一堂に会する初の同窓会を<br>
    開催いたします。<br>
    <br>
    大学ならびに校友会のご協力のもと、<br>
    今回の同窓会は<br>
    武蔵野美術大学 鷹の台キャンパス<br>
    鷹の台ホールで開催する<br>
    運びとなりました。<br>
    <br>
    会の詳細をお知らせいたしますので、<br>
    お手数ではございますが<br>
    下記リンク（Google Forms）から<br>
    あらためて出欠のご回答を<br>
    いただけますと幸いに存じます。
  </p>
  <p>
    ご回答期限：8月31日（月）まで
  </p>
    <!-- Event Details Box -->
     <div class="content__event-wrapper">
       <div class="content__event-box">
         <h2 class="content__event-title">開催概要</h2>
         <dl class="content__event-list">
            <div class="content__event-item">
              <dt>時期</dt>
              <dd>2026年11月28日（土）</dd>
            </div>
            <div class="content__event-item">
              <dt>時間</dt>
              <dd>開場 14:00 <br>開始 14:30<br>終了 16:30（予定）</dd>
            </div>
            <div class="content__event-item">
              <dt>場所</dt>
              <dd>武蔵野美術大学 <wbr />鷹の台キャンパス <wbr />鷹の台ホール</dd>
            </div>
            <div class="content__event-item">
              <dt>会費</dt>
              <dd>12,000円<br>
                  <span class="content__event-item__description">
                    事前オンライン決済を検討しておりますが、変更になる可能性もございます。決定次第、メールでご案内させていただきます。
                  </span>
              </dd>
            </div>
            <div class="content__event-item">
              <dt>服装</dt>
              <dd>スマートカジュアル</dd>
            </div>
          </dl>
          <ul class="content__notes">
            <li>当日はアルコール・ソフトドリンクの飲み放題と軽食をご用意いたします。</li>
            <li>誠に申し訳ございませんが、安全面などを考慮し、お子さまの同伴はご遠慮いただきますようお願いいたします。</li>
            <li>会費のお支払い方法など未定事項につきましては、追ってご案内させていただきます。</li>
            <li>万一、回答後にご参加が難しくなってしまった場合は、開催2週間前までに幹事チームまでご連絡をお願い申し上げます。</li>
          </ul>
        </div>
      </div>

  <p>
    みなさんと再会できることを<wbr />心から楽しみにしております。
  </p>

  <div class="asterisks">
    <img src={asset('assets/imgs/asterisk.svg')} alt="">
    <img src={asset('assets/imgs/asterisk.svg')} alt="">
    <img src={asset('assets/imgs/asterisk.svg')} alt="">
  </div>

    <!-- Signature -->
    <footer class="content__footer">
      <p class="content__signature">
        武蔵野美術大学 2006年卒業生<br />
        同窓会幹事チーム一同<br />
        <p class="content__contact">
          <a href="https://forms.gle/JydsrAB9Aiat345w6">
            <span class="content__contact-label">お問い合わせ</span>
          </a>
        </p>
      </p>
    </footer>
  </div>
</section>

<style>
  .content {
    /* background-color: var(--color-bg); */
    padding: var(--spacing-32) var(--spacing-24);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap:2rem;
    & h2 {
      text-align: center;
    }
    & p {
      word-break: keep-all;
      text-align: center;
      font-size: 1.2rem;
      line-height: 1.75;
      padding: var(--spacing-24)
    } 
  }

  .content__event-wrapper {
    background-color: white;
    padding: var(--spacing-16);
  }
  .content__event-box {
    background-color: white;
    border: 0.05rem solid var(--color-accent);
    padding: var(--spacing-24);
  }

  .content__event-title {
    font-size: calc(20 * var(--fluid-unit));
    font-weight: 900;
    text-align: center;
    margin-bottom: var(--spacing-16);
    letter-spacing: 0.1em;
  }

  @media (min-width: 641px) {
    .content__event-title {
      font-size: 16px;
    }
  }

  .content__event-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
    margin-bottom: var(--spacing-24);
  }

  .content__event-item {
    display: flex;
    gap: var(--spacing-8);
  }

  .content__event-item dt {
    flex-shrink: 0;
    width: calc(48 * var(--fluid-unit));
    font-weight: 900;
  }

  @media (min-width: 641px) {
    .content__event-item dt {
      width: 60px;
    }
  }

  .content__event-item dd {
    flex: 1;
  }
  .content__event-item__description{
    display: block;
    font-size: calc(12 * var(--fluid-unit));
    line-height: 1.4;
    margin-top: var(--spacing-8);
  }
  .content__footer {
    text-align: right;
  }

  .content__contact {
    margin-bottom: var(--spacing-32);
    font-size: calc(14 * var(--fluid-unit)) !important;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-8);
    padding: 0 !important;
  }

  @media (min-width: 641px) {
    .content__contact {
      font-size: 13px !important;
    }
  }

  .content__contact-label {
    color: var(--color-text);
    opacity: 0.6;
    letter-spacing: 0.05em;
  }

  .content__contact a {
    text-decoration: underline;
    text-underline-offset: 0.2em;
    letter-spacing: 0.03em;
  }

  .content__signature {
    font-size: calc(16 * var(--fluid-unit))!important;
    line-height: 1.6;
  }

  @media (min-width: 641px) {
    .content__signature {
      font-size: 14px;
    }
  }

.content__notes {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-8);
  font-size: calc(13 * var(--fluid-unit));
  & li {
    padding-left: 1.4em;
    position: relative;
    &::before {
      content: "※";
      position: absolute;
      left: 0;
    }
  }
}

@media (min-width: 641px) {
  .content__notes {
    font-size: 13px;
  }
}

.asterisks {
  display: flex;
  justify-content: center;
  gap: var(--spacing-32);
  & img {
    width: 1.5rem;
  }
}

</style>
